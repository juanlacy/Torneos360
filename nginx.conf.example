server {
    listen 80;
    server_name torneos360.huelemu.com.ar;
    return 301 https://$server_name$request_uri;
}

server {
    listen 443 ssl http2;
    server_name torneos360.huelemu.com.ar;

    ssl_certificate     /etc/letsencrypt/live/torneos360.huelemu.com.ar/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/torneos360.huelemu.com.ar/privkey.pem;

    # Frontend (Angular)
    root /www/wwwroot/torneos360/frontend/dist/frontend/browser;
    index index.html;

    location / {
        try_files $uri $uri/ /index.html;
    }

    # Backend API
    location ~ ^/(auth|admin|permisos|health|api-docs|uploads) {
        proxy_pass http://127.0.0.1:7300;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Socket.io — WebSocket upgrade
    location /socket.io/ {
        proxy_pass http://127.0.0.1:7300;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Gzip
    gzip on;
    gzip_types text/plain text/css application/json application/javascript text/xml application/xml;
    gzip_min_length 1000;

    # Cache para assets estaticos
    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf)$ {
        expires 1y;
        add_header Cache-Control "public, immutable";
    }
}
