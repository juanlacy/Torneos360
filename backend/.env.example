# ─── Servidor ─────────────────────────────────────────────────────────────
PORT=7300
NODE_ENV=development
TZ=America/Argentina/Buenos_Aires

# ─── Base de datos (PostgreSQL) ───────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=torneo360
DB_USER=postgres
DB_PASSWORD=

# ─── JWT ──────────────────────────────────────────────────────────────────
JWT_SECRET=cambiar-este-secreto-en-produccion
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=30d

# ─── Frontend ─────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:4300

# ─── Google OAuth ─────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=

# ─── Microsoft OAuth ──────────────────────────────────────────────────────
MICROSOFT_CLIENT_ID=
MICROSOFT_TENANT_ID=

# ─── Email (SES) ─────────────────────────────────────────────────────────
EMAIL_PROVIDER=smtp
SES_REGION=us-east-1
SES_ACCESS_KEY=
SES_SECRET_KEY=
SES_FROM_EMAIL=noreply@torneo360.com
EMAIL_FROM_NAME=Torneo360

# ─── Email (SMTP fallback) ───────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ─── Deshabilitar emails en desarrollo ───────────────────────────────────
DISABLE_EMAILS=true
